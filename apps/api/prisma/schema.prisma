generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  super_admin
  school_admin
  teacher
  student
  hr_admin
}

model School {
  id        String   @id @default(uuid())
  name      String
  nameBn    String?  @map("name_bn")
  address   String?
  phone     String?
  email     String?
  logo      String?
  domain    String?  @unique
  timezone  String   @default("Asia/Dhaka")
  startTime String   @default("07:30") @map("start_time")
  endTime   String   @default("14:30") @map("end_time")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  users     User[]
  teachers  Teacher[]
  students  Student[]
  departments Department[]
  subjects    Subject[]
  designations Designation[]

  @@map("schools")
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  name         String?
  role         UserRole @default(teacher)
  schoolId     String?  @map("school_id")
  isActive     Boolean  @default(true) @map("is_active")
  avatar       String?
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  school School? @relation(fields: [schoolId], references: [id], onDelete: SetNull)

  @@index([schoolId])
  @@map("users")
}

model Teacher {
  id              String   @id @default(uuid())
  schoolId        String   @map("school_id")
  nameEn          String   @map("name_en")
  nameBn          String?  @map("name_bn")
  gender          String?
  dob             String?
  bloodGroup      String?  @map("blood_group")
  religion        String?
  phone           String?
  email           String?
  address         String?
  nid             String?
  emergencyPhone  String?  @map("emergency_phone")
  photo           String?
  departmentId    String?  @map("department_id")
  subjectIds      String[] @default([]) @map("subject_ids")
  designation     String?
  qualification   String?
  experience      String?
  salary          Decimal?
  salaryStartDate String?  @map("salary_start_date")
  bonus           Decimal?
  overtime        Decimal?
  festivalBonus   Decimal? @map("festival_bonus")
  status          String   @default("active")
  category        String?
  joiningDate     String?  @map("joining_date")
  inTime          String?  @map("in_time")
  outTime         String?  @map("out_time")
  fatherNameEn    String?  @map("father_name_en")
  fatherNameBn    String?  @map("father_name_bn")
  fatherPhone     String?  @map("father_phone")
  fatherNid       String?  @map("father_nid")
  motherNameEn    String?  @map("mother_name_en")
  motherNameBn    String?  @map("mother_name_bn")
  motherPhone     String?  @map("mother_phone")
  guardianName    String?  @map("guardian_name")
  guardianPhone   String?  @map("guardian_phone")
  guardianRelation String? @map("guardian_relation")
  parentAddress   String?  @map("parent_address")
  signature       String?
  expertSubjects  String?  @map("expert_subjects")
  applySalaryRule Boolean? @default(false) @map("apply_salary_rule")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([schoolId])
  @@map("teachers")
}

model Department {
  id        String   @id @default(uuid())
  schoolId  String   @map("school_id")
  name      String
  nameBn    String?  @map("name_bn")
  head      String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@unique([name, schoolId])
  @@index([schoolId])
  @@map("departments")
}

model Subject {
  id           String   @id @default(uuid())
  schoolId     String   @map("school_id")
  name         String
  nameBn       String?  @map("name_bn")
  departmentId String?  @map("department_id")
  departmentIds String[] @default([]) @map("department_ids")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@unique([name, schoolId])
  @@index([schoolId])
  @@map("subjects")
}

model Designation {
  id        String   @id @default(uuid())
  schoolId  String   @map("school_id")
  name      String
  nameBn    String?  @map("name_bn")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@unique([name, schoolId])
  @@index([schoolId])
  @@map("designations")
}

model Student {
  id            String   @id @default(uuid())
  schoolId      String   @map("school_id")
  nameEn        String   @map("name_en")
  nameBn        String?  @map("name_bn")
  phone         String?
  email         String?
  photo         String?
  class         String?
  section       String?
  admissionDate String?  @map("admission_date")
  status        String   @default("approved")
  fatherNameEn  String?  @map("father_name_en")
  fatherPhone   String?  @map("father_phone")
  motherNameEn  String?  @map("mother_name_en")
  motherPhone   String?  @map("mother_phone")
  district      String?
  active        Boolean  @default(true)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([schoolId])
  @@map("students")
}
